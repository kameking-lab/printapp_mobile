{
  "expo": {
    "name": "パシャっと管理",
    "slug": "printapp_mobile",
    "version": "1.0.4",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "printappmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kamekinglab.printapp",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "お客様に最適な広告を表示するために使用します。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO",
        "com.google.android.gms.permission.AD_ID"
      ],
      "package": "com.kamekinglab.printapp",
      "versionCode": 4
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-calendar",
        {
          "calendarPermission": "プリントの予定をカレンダーに追加するためにカレンダーへのアクセスが必要です。"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "プリントを撮影するためにカメラを使います。",
          "photosPermission": "プリント画像を選ぶためにフォトライブラリを使います。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8751260838396451~7655709564",
          "iosAppId": "ca-app-pub-8751260838396451~1161114671"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "お客様に最適な広告を表示するために使用します。"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E6F4FE",
          "sounds": [],
          "defaultChannel": "calendar"
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "63f3d1fa-a06d-42d2-b641-e6b24f0f9b43"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/63f3d1fa-a06d-42d2-b641-e6b24f0f9b43"
    }
  }
}
