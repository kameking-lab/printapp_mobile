{
  "cli": {
    "version": ">= 18.0.3",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "env": {
        "EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME": "@kenshi.ycc/printapp_mobile"
      },
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME": "@kenshi.ycc/printapp_mobile"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_WEB": "937444991341-e2v8oi2n8lor4dk6vg0pd9tdvu61fv50.apps.googleusercontent.com"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
