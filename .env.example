# Gemini API キー（必須）
# 取得: https://aistudio.google.com/apikey
# Expo では必ず EXPO_PUBLIC_ プレフィックスを付けてください。
EXPO_PUBLIC_GEMINI_API_KEY=your_api_key_here

# プライバシーポリシー URL（任意）
# 未設定時はアプリ内のフォールバックURLを使用します。
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://docs.google.com/document/d/e/2PACX-1vSMcl_jmd_r_B_kL3lh4cmHn0M-zEVYEEDL_36l30hlarBIE4Nybj_a2FxK4vFHGj81a1eTOK61I2IF/pub

# Google OAuth（高速モード・API直接連携用・expo-auth-session）
# iOS: iOS 用 OAuth 2.0 クライアント ID
# Android: ブラウザベース OAuth では「ウェブアプリケーション」のクライアント ID を使う（Android タイプ ID は Error 400 になる）
# 未設定時、Android はコード内の本番 Web クライアント ID にフォールバックします。
# Android は Web クライアント利用時、Google が https の redirect_uri のみ許可するため Expo Auth プロキシを使用します。
# 次を .env に設定し、Google Cloud（ウェブアプリケーション）の「承認済みのリダイレクト URI」に
#   https://auth.expo.io/@あなたのExpoユーザー名/printapp_mobile
# をそのまま追加してください（slug は app.json の expo.slug = printapp_mobile）。
EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME=@あなたのExpoユーザー名/printapp_mobile
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_WEB=
# 旧 Android ネイティブ用 ID（AuthSession では使用しません。参考用）
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_ANDROID=
